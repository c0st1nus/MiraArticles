[Unit]
Description=MiraArticles news automation
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=miraarticles
WorkingDirectory=/opt/miraarticles
EnvironmentFile=/opt/miraarticles/.env
ExecStart=/usr/local/bin/bun run src/index.ts
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
