# Copy to .env — never commit .env or token/

# Telegram MTProto
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# Mira (@mira via MTProto)
MIRA_BOT_USERNAME=mira
# Leave TELEGRAM_API_ID/HASH unset to use token/telegram.json (empty .env lines override JSON!)
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
MIRA_RESPONSE_TIMEOUT_MS=180000
MIRA_POLL_INTERVAL_MS=2500

# Reddit — or load from token/reddit_token.json (copy of ~/.devvit/token)
REDDIT_CLIENT_ID=Bep8X2RRjuoyuxkKsKxFuQ
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=
